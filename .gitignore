# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
# package-lock.json IS committed for reproducible builds (re-affirmed 2026-05-20).
# CI uses `npm ci` to install exactly these versions. Do NOT add package-lock.json
# to this file - dropping it would let every CI install resolve different transitive
# deps (supply-chain regression). Dependabot updates the lockfile via PR.
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# SBOM output (CycloneDX). Generated by CI on main and uploaded as a build
# artifact for SOC 2 + supply-chain audits. Not committed to the repo.
/sbom.json
/.cyclonedx-output/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
supabase/.temp/

# Claude Code local settings (per-developer, not committed)
.claude/settings.local.json
.claude/worktrees/
.env*.local
