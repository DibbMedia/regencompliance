# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — set STRIPE_RESTRICTED_KEY (preferred) OR STRIPE_SECRET_KEY.
# Rotation procedure: docs/stripe-restricted-key-setup.md
STRIPE_RESTRICTED_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_BETA_PRICE_ID=

# Anthropic
ANTHROPIC_API_KEY=

# AI spend kill-switch (cents). Opt-in: disabled when unset or 0.
# Example: 5000 = $50/day platform-wide cap. See lib/ai-spend-guard.ts.
AI_SPEND_DAILY_CAP_CENTS=

# Cron protection (Bearer token for Vercel cron endpoints).
# Generate with `openssl rand -hex 32` (64 hex chars, 256 bits, URL-safe).
CRON_SECRET=

# Application-layer encryption key for lib/crypto.ts (AES-256-GCM + HMAC).
# Generate with `openssl rand -hex 32`. Optional until a caller needs it.
# Rotation: add ENCRYPTION_KEY_V2 alongside, migrate envelopes, then retire V1.
ENCRYPTION_KEY_V1=

# Resend (transactional email) — optional; sendEmail() no-ops when unset.
RESEND_API_KEY=
FROM_EMAIL=RegenCompliance <noreply@regenportal.com>

# Sentry — optional; wrapper is a no-op when DSN unset.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Admin shortcut — optional. When set and matching the logged-in user,
# grants developer-admin. Otherwise platform_admins table is canonical.
ADMIN_EMAIL=

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=RegenCompliance

# Launch gating
NEXT_PUBLIC_LAUNCHED=false

# Promo code embedded in the launch-announcement email (server-only,
# not shipped to the browser bundle). The legacy NEXT_PUBLIC_ name is
# still accepted for one release as a fallback — please rename in Vercel
# and remove the old var.
EARLY_ACCESS_CODE=
