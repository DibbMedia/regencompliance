# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — set STRIPE_RESTRICTED_KEY (preferred) OR STRIPE_SECRET_KEY.
# Rotation procedure: docs/stripe-restricted-key-setup.md
STRIPE_RESTRICTED_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_BETA_PRICE_ID=

# Anthropic
ANTHROPIC_API_KEY=

# AI spend kill-switch (cents). Opt-in: disabled when unset or 0.
# Example: 5000 = $50/day platform-wide cap. See lib/ai-spend-guard.ts.
AI_SPEND_DAILY_CAP_CENTS=

# Cron protection (Bearer token for Vercel cron endpoints)
CRON_SECRET=

# Resend (transactional email) — optional; sendEmail() no-ops when unset.
RESEND_API_KEY=
FROM_EMAIL=RegenCompliance <noreply@regenportal.com>

# Sentry — optional; wrapper is a no-op when DSN unset.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Admin shortcut — optional. When set and matching the logged-in user,
# grants developer-admin. Otherwise platform_admins table is canonical.
ADMIN_EMAIL=

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=RegenCompliance

# Launch gating
NEXT_PUBLIC_LAUNCHED=false
NEXT_PUBLIC_EARLY_ACCESS_CODE=
